# Regression-test environment variables.
# See utils/env.ts for the full contract; every variable below is the only
# form this project reads. Unset values fall back to safe defaults.

# ─── App under test ───────────────────────────────────────────────────────
# URL Playwright points at. Examples:
#   http://localhost:3000          (local dev)
#   https://portal.finops.s1.today (shared dev)
BASE_URL=http://localhost:3000

# Cluster URL to proxy API requests to (`POST /restapi/v2/live_demo`) plus the
# bearer token it expects in the `X-LiveDemo-Token` header.
# Required only when regenerating the cached session (every ~6 days).
HOST_URL=
HOST_ACCOUNT_API_TOKEN=

# ─── Run modes ────────────────────────────────────────────────────────────
# Set to `true` to compare against snapshots/baseline/<host>/ instead of
# the gitignored snapshots/local/<platform>/ folder. CI should set this.
IS_REGRESSION_RUN=false

# Accept self-signed / expired certs (useful when BASE_URL is an internal host).
IGNORE_HTTPS_ERRORS=false

# ─── Debug hooks ──────────────────────────────────────────────────────────
# Emit [DEBUG]-prefixed Node-side logs from `debugLog`.
DEBUG_LOG=false

# Forward browser `console.error` output to the Node test runner.
BROWSER_ERROR_LOGGING=false
