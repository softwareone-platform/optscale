# OptScale Docker Compose quickstart configuration
# Copy this file to .env and adjust as needed:
#   cp .env.example .env

# ── Image version ──────────────────────────────────────────────
# Use a git tag from https://github.com/hystax/optscale/releases
# or "local" if you built images yourself with build.sh.
OPTSCALE_VERSION=latest
COMPANY=hystax

# ── Network ────────────────────────────────────────────────────
# Port exposed on the Docker host for the edge proxy (HTTP).
EDGE_PORT=80

# ── MariaDB ────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=my-password-01

# ── MongoDB ────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=SecurePassword-01-02

# ── RabbitMQ ───────────────────────────────────────────────────
RABBITMQ_USER=optscale
RABBITMQ_PASSWORD=secure-password-here
RABBITMQ_ERLANG_COOKIE=dWkhXehOApH1OHshvByfpfTf3Cd8wwkADei7mWd5JF

# ── ClickHouse ─────────────────────────────────────────────────
CLICKHOUSE_PASSWORD=secure-password-1-clk

# ── MinIO (S3-compatible object store for Thanos) ──────────────
MINIO_ACCESS_KEY=optscale-minio
MINIO_SECRET_KEY=secret_password

# ── Cluster secret (shared between report-import-scheduler & restapi) ──
CLUSTER_SECRET=change-me-in-production

# ══════════════════════════════════════════════════════════════════
# Optional integrations — uncomment and fill in to enable.
# ══════════════════════════════════════════════════════════════════

# ── OAuth (social login) ───────────────────────────────────────
# https://console.developers.google.com/ for Google OAuth client
# https://portal.azure.com/ for Microsoft OAuth client
#GOOGLE_OAUTH_CLIENT_ID=
#GOOGLE_OAUTH_CLIENT_SECRET=
#MICROSOFT_OAUTH_CLIENT_ID=

# ── Slack integration ──────────────────────────────────────────
#SLACK_SIGNING_SECRET=
#SLACK_CLIENT_ID=
#SLACK_CLIENT_SECRET=

# ── Google Maps (used in finops dashboards) ────────────────────
#GOOGLE_MAP_API_KEY=

# ── Email verification ─────────────────────────────────────────
# Disabled by default for quickstart (no SMTP needed to register).
# To enable, set disable_email_verification to "" in config.yml
# and configure the smtp section there.
# Current value in config.yml: disable_email_verification: True
